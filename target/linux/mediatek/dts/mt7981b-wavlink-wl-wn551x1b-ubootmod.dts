/dts-v1/;

#include "mt7981b-wavlink-wl-wn551x1b.dtsi"

/ {
	model = "WAVLINK WL-WN551X1 Rev B (OpenWrt U-Boot layout)";
	compatible = "wavlink,wl-wn551x1b-ubootmod", "mediatek,mt7981b";
};

&chosen {
	bootargs = "root=/dev/fit0 rootwait";
	rootdisk = <&ubi_rootdisk>;
};

&ubi {
	reg = <0x580000 0x7a80000>;

	volumes {
		ubi_rootdisk: ubi-volume-fit {
			volname = "fit";
		};
	};
};
